{
  "name": "@vishot/cli",
  "type": "module",
  "version": "0.0.0",
  "description": "Unified command line interface for Vishot capture adapters.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "types": "./dist/index.d.mts",
  "bin": {
    "vishot": "./dist/bin/index.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@moeru/std": "catalog:",
    "@napi-rs/image": "catalog:",
    "@vishot/core": "workspace:*",
    "@vishot/renderer-browser": "workspace:*",
    "@vishot/source-electron": "workspace:*",
    "cac": "catalog:",
    "playwright": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:"
  }
}
