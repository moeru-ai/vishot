    },
    "./files": {
      "types": "./dist/files.d.mts",
      "import": "./dist/files.mjs"
    },
    "./ready": {
      "types": "./dist/ready.d.mts",
      "import": "./dist/ready.mjs"
    },
    "./selectors": {
      "types": "./dist/selectors.d.mts",
      "import": "./dist/selectors.mjs"
    }
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
