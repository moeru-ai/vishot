{
  "name": "@vishot/root",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Composable screenshot sources, browser renderers, and desktop mockup components.",
  "author": {
    "name": "Moeru AI",
    "url": "https://github.com/moeru-ai"
  },
  "license": "MIT",
  "scripts": {
    "alint": "alint",
    "build": "pnpm -r build",
    "dev:mockup": "pnpm -F @vishot/mockup-desktop-vue story:dev",
    "docs:sync-readme": "tsx scripts/sync-cli-readme.ts",
    "docs:toc": "doctoc --github --title \"## Table of Contents\" --maxlevel=2 README.md",
    "docs:update": "pnpm docs:toc && pnpm docs:sync-readme",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "bumpp",
    "test": "pnpm -r --parallel test:run",
    "typecheck": "pnpm -r --parallel typecheck"
  },
  "devDependencies": {
    "@alint-js/cli": "catalog:",
    "@alint-js/plugin-js": "catalog:",
    "@antfu/eslint-config": "catalog:",
    "@histoire/plugin-vue": "catalog:",
    "@moeru/eslint-config": "catalog:",
    "@types/node": "catalog:",
    "@unocss/eslint-config": "catalog:",
    "@unocss/eslint-plugin": "catalog:",
    "@unocss/preset-web-fonts": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "bumpp": "catalog:",
    "doctoc": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "histoire": "catalog:",
    "oxc-minify": "catalog:",
    "oxlint": "catalog:",
    "playwright": "catalog:",
    "tinyexec": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "unocss": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
